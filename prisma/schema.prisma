generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  password      String?
  nombre        String
  apellido      String
  telefono      String?
  avatar        String?
  rol           Rol          @default(CLIENTE)
  activo        Boolean      @default(true)
  emailVerified DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  cliente       Cliente?
  cuentas       Account[]
  otpRequests   OtpRequest[]
  sesiones      Session[]

  sucursalId String?
  sucursal   Sucursal? @relation(fields: [sucursalId], references: [id])

  @@map("usuarios")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "cuentas_userId_fkey")
  @@map("cuentas")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sesiones_userId_fkey")
  @@map("sesiones")
}

model OtpRequest {
  id         String   @id @default(cuid())
  userId     String?
  telefono   String
  codigo     String
  tipo       String
  verificado Boolean  @default(false)
  intentos   Int      @default(0)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([telefono])
  @@index([userId], map: "otp_requests_userId_fkey")
  @@map("otp_requests")
}

model Cliente {
  id           String        @id @default(cuid())
  usuarioId    String        @unique
  nombre       String
  apellido     String
  email        String
  telefono     String
  direccion    String
  ciudad       String
  codigoPostal String
  notas        String?       @db.Text
  activo       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  usuario      User          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  membresias   Membresia[]
  pagos        Pago[]
  presupuestos Presupuesto[]
  solicitudes  Solicitud[]

  @@index([email])
  @@index([telefono])
  @@map("clientes")
}

model Membresia {
  id                   String          @id @default(cuid())
  clienteId            String
  plan                 PlanMembresia
  precio               Decimal         @db.Decimal(10, 2)
  estado               EstadoMembresia @default(ACTIVA)
  fechaInicio          DateTime
  fechaFin             DateTime?
  fechaProximoPago     DateTime
  serviciosDisponibles Int
  serviciosUsados      Int             @default(0)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  cliente              Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  pagos                Pago[]

  @@index([clienteId])
  @@index([estado])
  @@map("membresias")
}

model Servicio {
  id               String            @id @default(cuid())
  nombre           String
  descripcion      String            @db.Text
  categoria        CategoriaServicio
  tarifaBase       Decimal           @db.Decimal(10, 2)
  duracionEstimada Int
  activo           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  solicitudes      Solicitud[]

  @@index([categoria])
  @@map("servicios")
}

model Solicitud {
  id              String          @id @default(cuid())
  clienteId       String
  servicioId      String
  direccion       String
  ciudad          String
  descripcion     String          @db.Text
  estado          EstadoSolicitud @default(PENDIENTE)
  prioridad       Prioridad       @default(MEDIA)
  fechaSolicitada DateTime        @default(now())
  fechaProgramada DateTime?
  fechaCompletada DateTime?
  notas           String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  presupuesto     Presupuesto?
  cliente         Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  servicio        Servicio        @relation(fields: [servicioId], references: [id])

  @@index([clienteId])
  @@index([estado])
  @@index([servicioId], map: "solicitudes_servicioId_fkey")
  @@map("solicitudes")
}

model Presupuesto {
  id                  String            @id @default(cuid())
  numero              Int               @unique @default(autoincrement())
  clienteId           String?
  solicitudId         String?           @unique
  clienteNombre       String?
  clienteDireccion    String?
  clienteTelefono     String?
  clienteEmail        String?
  lugar               String            @default("La Plata")
  fecha               DateTime          @default(now())
  subtotal            Decimal           @db.Decimal(12, 2)
  descuentoPorcentaje Decimal           @default(0.00) @db.Decimal(5, 2)
  descuentoMonto      Decimal           @default(0.00) @db.Decimal(12, 2)
  iva                 Decimal           @default(0.00) @db.Decimal(12, 2)
  total               Decimal           @db.Decimal(12, 2)
  financiacion        String            @default("contado")
  cuotas              Int               @default(1)
  estado              EstadoPresupuesto @default(PENDIENTE)
  fechaEmision        DateTime          @default(now())
  fechaValidez        DateTime?
  notas               String?           @db.Text
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  pagos               Pago[]
  items               PresupuestoItem[]
  cliente             Cliente?          @relation(fields: [clienteId], references: [id])
  solicitud           Solicitud?        @relation(fields: [solicitudId], references: [id])

  @@index([clienteId])
  @@index([estado])
  @@index([solicitudId])
  @@map("presupuestos")
}

model PresupuestoItem {
  id             String      @id @default(cuid())
  presupuestoId  String
  descripcion    String
  cantidad       Decimal     @db.Decimal(10, 2)
  precioUnitario Decimal     @db.Decimal(12, 2)
  subtotal       Decimal     @db.Decimal(12, 2)
  presupuesto    Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)

  @@index([presupuestoId], map: "presupuesto_items_presupuestoId_fkey")
  @@map("presupuesto_items")
}

model Pago {
  id            String       @id @default(cuid())
  clienteId     String
  membresiaId   String?
  presupuestoId String?
  monto         Decimal      @db.Decimal(12, 2)
  metodo        MetodoPago
  estado        EstadoPago   @default(PENDIENTE)
  referencia    String?
  fechaPago     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  cliente       Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  membresia     Membresia?   @relation(fields: [membresiaId], references: [id])
  presupuesto   Presupuesto? @relation(fields: [presupuestoId], references: [id])

  @@index([clienteId])
  @@index([membresiaId], map: "pagos_membresiaId_fkey")
  @@index([presupuestoId], map: "pagos_presupuestoId_fkey")
  @@map("pagos")
}

model Lead {
  id           String     @id @default(cuid())
  nombre       String
  telefono     String
  email        String?
  zona         String
  necesidad    String     @db.Text
  conversacion String?    @db.LongText
  estado       EstadoLead @default(NUEVO)
  clienteId    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([estado])
  @@index([telefono])
  @@map("leads")
}

model NotificacionWhatsApp {
  id           String             @id @default(cuid())
  tipo         String
  destino      String
  mensaje      String             @db.Text
  estado       EstadoNotificacion @default(PENDIENTE)
  referenciaId String?
  error        String?            @db.Text
  enviadoAt    DateTime?
  createdAt    DateTime           @default(now())

  @@index([estado])
  @@map("notificaciones_whatsapp")
}

model Tecnico {
  id           String   @id @default(cuid())
  nombre       String
  apellido     String
  especialidad String?
  telefono     String?
  avatar       String?
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([activo])
  @@map("tecnicos")
}

model KbArticulo {
  id         String        @id @default(cuid())
  titulo     String
  contenido  String        @db.Text
  categoria  String
  activo     Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  embeddings KbEmbedding[]

  @@index([categoria])
  @@map("kb_articulos")
}

model KbEmbedding {
  id         String     @id @default(cuid())
  articuloId String
  contenido  String     @db.Text
  embedding  String     @db.Text
  createdAt  DateTime   @default(now())
  articulo   KbArticulo @relation(fields: [articuloId], references: [id], onDelete: Cascade)

  @@index([articuloId], map: "kb_embeddings_articuloId_fkey")
  @@map("kb_embeddings")
}

model Configuracion {
  id          String   @id @default(cuid())
  clave       String   @unique
  valor       String   @db.Text
  descripcion String?
  updatedAt   DateTime @updatedAt

  @@map("configuracion")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("tokens_verificacion")
}

enum Rol {
  SUPER
  ADMIN
  CLIENTE
}

enum PlanMembresia {
  BASICO
  ESTANDAR
  PREMIUM
}

enum EstadoMembresia {
  ACTIVA
  PAUSADA
  CANCELADA
  VENCIDA
}

enum CategoriaServicio {
  MANTENIMIENTO
  OBRA
  INSTALACION
  REPARACION
}

enum EstadoSolicitud {
  PENDIENTE
  CONFIRMADA
  EN_PROGRESO
  COMPLETADA
  CANCELADA
}

enum Prioridad {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum EstadoPresupuesto {
  PENDIENTE
  APROBADO
  RECHAZADO
  VENCIDO
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
  MERCADOPAGO
}

enum EstadoPago {
  PENDIENTE
  COMPLETADO
  FALLIDO
  REEMBOLSADO
}

enum EstadoLead {
  NUEVO
  CONTACTADO
  CALIFICADO
  CONVERTIDO
  PERDIDO
}

enum EstadoNotificacion {
  PENDIENTE
  ENVIADO
  FALLIDO
}

model Sucursal {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios  User[]

  @@map("sucursales")
}